{
  "name": "PawSpellProfile",
  "type": "object",
  "properties": {
    "profileId": {
      "type": "string",
      "description": "UserProfile ID"
    },
    "username": {
      "type": "string"
    },
    "tokens": {
      "type": "number",
      "default": 100
    },
    "wins": {
      "type": "number",
      "default": 0
    },
    "losses": {
      "type": "number",
      "default": 0
    },
    "ownedSkinIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "equippedSkins": {
      "type": "object",
      "description": "{ petType: skinId } map for white side. skinId can be 'pet_<customPetId>' for pet-derived skins.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "petSkinMap": {
      "type": "object",
      "description": "Maps 'pet_<id>' pseudo-skin keys to their imageUrl for quick lookup in-game",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": [
    "profileId",
    "username"
  ]
}