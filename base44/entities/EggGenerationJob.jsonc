{
  "name": "EggGenerationJob",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ],
      "default": "pending",
      "description": "Current job status"
    },
    "idea": {
      "type": "string",
      "description": "The creature idea prompt"
    },
    "totalCount": {
      "type": "number",
      "description": "Total creatures to generate"
    },
    "completedCount": {
      "type": "number",
      "default": 0,
      "description": "Number of creatures completed so far"
    },
    "currentStep": {
      "type": "string",
      "description": "What the job is currently doing"
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "emoji": {
            "type": "string"
          },
          "rarity": {
            "type": "string"
          },
          "theme": {
            "type": "object",
            "properties": {
              "primary": {
                "type": "string"
              },
              "secondary": {
                "type": "string"
              },
              "accent": {
                "type": "string"
              },
              "bg": {
                "type": "string"
              }
            }
          }
        }
      },
      "description": "Pre-confirmed pet concepts (skips LLM concept generation when provided)"
    },
    "createdPetIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs of pets created by this job"
    },
    "createdThemeIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs of themes created by this job"
    },
    "error": {
      "type": "string",
      "description": "Error message if failed"
    },
    "startedBy": {
      "type": "string",
      "description": "Admin user who started this job"
    },
    "startedByProfileId": {
      "type": "string",
      "description": "Profile ID of admin who started"
    }
  },
  "required": [
    "idea",
    "totalCount"
  ]
}