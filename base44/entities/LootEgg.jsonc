{
  "name": "LootEgg",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Egg name (e.g. Golden Egg, Mystery Egg)"
    },
    "description": {
      "type": "string",
      "description": "Short description"
    },
    "emoji": {
      "type": "string",
      "default": "\ud83e\udd5a",
      "description": "Emoji icon (fallback if no image)"
    },
    "imageUrl": {
      "type": "string",
      "description": "AI-generated egg image URL"
    },
    "color": {
      "type": "string",
      "default": "#6366f1",
      "description": "Primary color hex"
    },
    "prizes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "pet",
              "theme",
              "xp",
              "coins",
              "magic_egg",
              "title",
              "cosmetic"
            ]
          },
          "label": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          }
        }
      },
      "description": "Array of prizes with type, label, value, and weight (chance)"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "inVendingMachine": {
      "type": "boolean",
      "default": false,
      "description": "Whether this egg appears in the Kitchen Egg Shop vending machine"
    },
    "vendingGemPrice": {
      "type": "number",
      "default": 2,
      "description": "Cost in gems (Quest Coins) to purchase from the vending machine"
    }
  },
  "required": [
    "name",
    "prizes"
  ]
}